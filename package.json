{
  "name": "autopilot",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "bun --filter='*' run dev",
    "build": "bun --filter='*' run build",
    "typecheck": "bun --filter='*' run typecheck",
    "test": "bun --filter='*' run test",
    "ci:check-pr-size": "bun scripts/ci/check-pr-size.ts",
    "ci:check-migration-journal": "bun scripts/ci/check-migration-journal.ts"
  }
}
