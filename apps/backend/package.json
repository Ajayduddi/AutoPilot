{
  "name": "backend",
  "version": "0.1.0",
  "license": "Apache-2.0",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "start": "bun src/index.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "lint": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:push": "tsx src/db/guarded-push.ts",
    "db:push:guarded": "tsx src/db/guarded-push.ts",
    "db:migrate": "drizzle-kit migrate",
    "db:seed": "tsx src/db/seed.ts",
    "db:preflight": "tsx src/db/preflight.ts",
    "db:repair": "tsx src/db/repair.ts",
    "db:repair:analyze": "tsx src/db/repair.ts --analyze",
    "db:repair:apply": "tsx src/db/repair.ts --apply"
  },
  "dependencies": {
    "@autopilot/shared": "workspace:*",
    "@mastra/core": "^1.17.0",
    "@mastra/mcp": "^1.3.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.21.0",
    "postgres": "^3.4.8",
    "web-push": "^3.6.7",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
